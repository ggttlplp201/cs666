# .env.example — copy to .env and fill in. NEVER commit real secrets.
# Names only; blank values. See config/shared.yaml and HANDOFF.md.

# --- Data feeds ---------------------------------------------------------------
CS2SH_API_KEY=          # cs2.sh Developer tier: /v1/prices/latest — bid/ask + depth
                        # only (USD-normalized; no volume/float/supply on this tier)
STEAM_LOGIN_SECURE=     # steamLoginSecure cookie from a logged-in Steam session —
                        # Phase 1 FREE backtest history (daily median + qty sold)
HISTORY_API_KEY=        # Phase 2 ONLY (cs2.sh Scale / CSPriceAPI / csmarketapi /
                        # SteamAnalyst) — leave blank until the Phase-1 backtest
                        # shows an edge net of fees

# --- BUFF execution (official API path or unofficial session) -----------------
BUFF_API_KEY=           # Option A: official BUFF/NetEase API
BUFF_SESSION=           # Option B: unofficial session token
BUFF_USERNAME=          # BUFF account (if session path)
BUFF_PASSWORD=          # BUFF password (if session path)

# --- Social monitor -----------------------------------------------------------
X_API_KEY=              # X/Twitter API access (or chosen scraping method)
X_API_SECRET=
X_BEARER_TOKEN=

# --- LLM (signal classification) ----------------------------------------------
ANTHROPIC_API_KEY=      # Claude API key for classification (or self-hosted model)
